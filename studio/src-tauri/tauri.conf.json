{
  "productName": "Unsloth Studio",
  "identifier": "ai.unsloth.studio",
  "build": {
    "beforeDevCommand": "sh -c 'if [ -f package.json ] && [ -f vite.config.ts ]; then npm run dev -- --port 5173 --strictPort; elif [ -f frontend/package.json ]; then npm --prefix frontend run dev -- --port 5173 --strictPort; else cd ../frontend && npm run dev -- --port 5173 --strictPort; fi'",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* ws://127.0.0.1:* http://127.0.0.1:* https://huggingface.co https://*.huggingface.co https://datasets-server.huggingface.co; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    },
    "windows": [
      {
        "label": "main",
        "title": "Unsloth Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "id": "main",
      "tooltip": "Unsloth Studio"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "dmg", "nsis"],
    "resources": {
      "../../install.sh": "install.sh",
      "../../install.ps1": "install.ps1"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "postRemoveScript": "./linux/postremove.sh"
      },
      "rpm": {
        "postRemoveScript": "./linux/postremove.sh"
      }
    },
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 }
      }
    }
  }
}
