        "model_alias": "ministral",
        "system_prompt": null,
        "multi_modal_context": null,
        "tool_alias": null,
        "with_trace": "none",
        "extract_reasoning_content": false
      },
      {
        "name": "instruction",
        "drop": false,
        "allow_resize": false,
        "column_type": "seed-dataset"
      },
      {
        "name": "input",
        "drop": false,
        "allow_resize": false,
        "column_type": "seed-dataset"
      },
      {
        "name": "output",
        "drop": false,
        "allow_resize": false,
        "column_type": "seed-dataset"
      }
